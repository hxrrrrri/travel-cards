# TripGraph Environment Configuration
# Copy this to .env and fill in your values

# ─── App Mode ───────────────────────────────────────────────────────────────
APP_ENV=development

# Set to true to use demo data (no API keys required)
DEMO_MODE=true

# ─── Provider Selection ──────────────────────────────────────────────────────
MAP_PROVIDER=openstreetmap        # openstreetmap | mapbox
PLACE_PROVIDER=demo               # demo | google | mapbox
ROUTING_PROVIDER=demo             # demo | google | mapbox | osrm

# ─── Map API Keys ────────────────────────────────────────────────────────────
# Mapbox (https://account.mapbox.com/)
MAPBOX_ACCESS_TOKEN=

# Google (https://console.cloud.google.com/)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=

# ─── Backend ─────────────────────────────────────────────────────────────────
# If using self-hosted backend
API_BASE_URL=http://localhost:8080

# If using Supabase (https://supabase.com/)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Demo Configuration ──────────────────────────────────────────────────────
# Default demo location (Madikeri, Coorg, India)
DEMO_LAT=12.3375
DEMO_LNG=75.8069
DEMO_LOCATION_NAME=Madikeri, Coorg
